  "wording_preferences": {
    "prefer": [
      "compatible_with",
      "vendor_defined",
      "observed_stable_pattern",
      "candidate_interpretation",
      "linkage_feasibility"
    ],
    "avoid": [
      "confirmed_official_mapping",
      "verified_business_meaning",
      "proven_aggressor_side",
      "official_schema_identity"
    ]
